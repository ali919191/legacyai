# ── Legacy AI Platform — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose.
#
#   cp .env.example .env
#
# Values marked CHANGE ME must be set before running in any environment.

# ── Backend ──────────────────────────────────────────────────────────────────
# Port the backend API listens on (host side)
BACKEND_PORT=5000

# Flask secret key used for JWT signing — CHANGE ME
JWT_SECRET_KEY=change-me-in-production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=legacyai
POSTGRES_PASSWORD=legacyai_secret      # CHANGE ME
POSTGRES_DB=legacyai
POSTGRES_PORT=5432

# ── Qdrant (Vector Database) ──────────────────────────────────────────────────
QDRANT_PORT=6333

# ── OpenAI (optional — for LLM-powered features) ─────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Media Storage ────────────────────────────────────────────────────────────
# Local path inside the container where uploaded media is stored
MEDIA_STORAGE_PATH=/app/data/media

# ── Flask ─────────────────────────────────────────────────────────────────────
# Set to 'development' for debug mode, 'production' for gunicorn
FLASK_ENV=production
