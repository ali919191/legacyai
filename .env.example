# ── Legacy AI Platform — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose.
#
#   cp .env.example .env
#
# Values marked CHANGE ME must be set before running in any environment.

# ── Backend ──────────────────────────────────────────────────────────────────
# Port the backend API listens on (host side). FastAPI/uvicorn default is 8000.
BACKEND_PORT=8000

# Flask secret key used for JWT signing — CHANGE ME
JWT_SECRET_KEY=change-me-in-production

# Logging level for the application (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# CORS origins allowed to call the API (comma-separated). Use * only in dev.
# CORS_ORIGINS=https://your-frontend.example.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=legacyai
POSTGRES_PASSWORD=legacyai_secret      # CHANGE ME
POSTGRES_DB=legacyai
POSTGRES_PORT=5432

# ── Qdrant (Vector Database) ──────────────────────────────────────────────────
QDRANT_PORT=6333

# ── OpenAI (optional — for LLM-powered embedding and conversation features) ───
OPENAI_API_KEY=

# ── Vector Store ──────────────────────────────────────────────────────────────
# Storage backend for memory embeddings.
# Options: local (JSON file), pgvector, pinecone, weaviate
VECTOR_STORE_TYPE=local

# Path to the local JSON embedding file (used when VECTOR_STORE_TYPE=local)
VECTOR_STORE_FILE=memory_embeddings.json

# ── Media Storage ─────────────────────────────────────────────────────────────
# Local path inside the container where uploaded media files are stored
MEDIA_STORAGE_PATH=/app/data/media

# ── Persona ───────────────────────────────────────────────────────────────────
# Birth date of the person whose memories are preserved (ISO format: YYYY-MM-DD)
# Used by TimelineEngine to calculate ages and assign life stages.
PERSONA_BIRTH_DATE=1950-01-01

# ── Flask (legacy entry point — backend/app.py) ───────────────────────────────
# Set to 'development' for debug mode, 'production' for gunicorn
FLASK_ENV=production
